.gitignore
# Latex build files
*.glo
*.ist
*.loe
*.lol
*.lox
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.fmt
*.fot
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
annora*
test*

# Latexmk
latexmk

# Generated PDFs
*.pdf

# Exception: keep included asset pdfs
!assets/pdfs/include.pdf

# Temporary files
*.tmp
*.temp

# Backup files
*~
*.bak

# VSCode
.vscode/

# JetBrains
.idea/

# Linux
.DS_Store
Thumbs.db

# Python cache if you use scripts
__pycache__/
*.pyc
